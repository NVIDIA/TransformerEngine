ARG FROM_IMAGE_DEVEL
ARG FROM_IMAGE
ARG FRAMEWORK=pytorch

FROM ${FROM_IMAGE_DEVEL} as devel
FROM ${FROM_IMAGE}

ARG FRAMEWORK
WORKDIR /opt/transformerengine/
SHELL ["bash", "-c"]

# Remove PyTorch tests if not needed
RUN [[ ! "${FRAMEWORK}" =~ pytorch|all ]] \
    && rm -rf /opt/transformerengine/qa/L?_pytorch_* \
    || [[ "${FRAMEWORK}" =~ pytorch|all ]]
RUN rm -rf /opt/transformerengine/qa/L1_pytorch_distributed_unittest  # TODO Restore

# Remove JAX tests if not needed
RUN [[ ! "${FRAMEWORK}" =~ jax|all ]] \
    && rm -rf /opt/transformerengine/qa/L?_jax_* \
    || [[ "${FRAMEWORK}" =~ jax|all ]]

# Remove PaddlePaddle tests if not needed
RUN [[ ! "${FRAMEWORK}" =~ paddle|all ]] \
    && rm -rf /opt/transformerengine/qa/L?_paddle_* \
    || [[ "${FRAMEWORK}" =~ paddle|all ]]
