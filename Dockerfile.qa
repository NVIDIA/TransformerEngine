ARG FROM_IMAGE_DEVEL
ARG FROM_IMAGE

FROM ${FROM_IMAGE_DEVEL} as devel
FROM ${FROM_IMAGE}

COPY --from=devel /opt/transformerengine/qa /opt/transformerengine/qa
COPY --from=devel /opt/transformerengine/pylintrc /opt/transformerengine/
COPY --from=devel /opt/transformerengine/CPPLINT.cfg /opt/transformerengine/
